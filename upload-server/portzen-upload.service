[Unit]
Description=PortZen Upload Server
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/mnt/f/photographer-red/upload-server
ExecStart=/usr/bin/node /mnt/f/photographer-red/upload-server/server.js
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=portzen-upload
EnvironmentFile=/mnt/f/photographer-red/upload-server/.env

[Install]
WantedBy=multi-user.target
